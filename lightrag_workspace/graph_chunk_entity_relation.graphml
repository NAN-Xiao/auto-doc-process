  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Alliance" target="Instance Points">
  <data key="d7">2.0</data>
  <data key="d8">Instance Points accumulated by an alliance determine the winner of the GVG instance when the valid time expires.&lt;SEP&gt;An Alliance earns Instance Points in the GvG Instance by capturing Contestable Buildings and defeating enemy Player Troops.</data>
  <data key="d9">competition,competition outcome,scoring,victory condition</data>
  <data key="d10">chunk-a512646597d2b7b2699f5e2e5c8f4a4e&lt;SEP&gt;chunk-978055161286ec0d66cfcb71c8e04785</data>
