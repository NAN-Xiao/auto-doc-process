  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Player" target="Registration List">
  <data key="d7">1.0</data>
  <data key="d8">The Registration List consists of specific Players selected from the Alliance to participate in the GVG activity.</data>
  <data key="d9">eligibility,inclusion</data>
