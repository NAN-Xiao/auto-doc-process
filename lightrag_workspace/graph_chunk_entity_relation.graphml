  <data key="d12">1772784708</data>
  <data key="d13"></data>
</edge>
<edge source="Battle Instance" target="Player">
  <data key="d7">1.0</data>
  <data key="d8">Players can enter the Battle Instance manually via the UI, provided they meet the Entry Conditions.</data>
  <data key="d9">access,participation</data>
