  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Bye Win" target="Matching Rules">
  <data key="d7">1.0</data>
  <data key="d8">The Matching Rules include the Bye Win condition to handle alliances that remain unpaired after the matching process.</data>
