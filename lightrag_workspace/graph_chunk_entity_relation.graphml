  <data key="d12">1772784708</data>
  <data key="d13"></data>
</edge>
<edge source="Play Configuration Table" target="Blackboard">
  <data key="d7">1.0</data>
  <data key="d8">The Blackboard loads data from the Play Configuration Table to make it available as parameters for triggers and conditions.</data>
  <data key="d9">data loading,parameter management</data>
