  <data key="d13"></data>
</edge>
<edge source="Battle Session" target="GVG Configuration Table">
  <data key="d7">1.0</data>
  <data key="d8">The GVG Configuration Table is used to configure the total number of Battle Sessions (M) and the maximum number a player can select (N).</data>
