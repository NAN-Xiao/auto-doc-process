  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Blackboard" target="InstanceTag Table">
  <data key="d7">1.0</data>
  <data key="d8">Based on the InstanceGroup Id, the InstanceTag Table loads specific character ID data into the Blackboard for use in triggers and conditions.</data>
  <data key="d9">data association,parameter provisioning</data>
  <data key="d10">chunk-0a1bbafca3103b090e8933ba19fbacf9</data>
