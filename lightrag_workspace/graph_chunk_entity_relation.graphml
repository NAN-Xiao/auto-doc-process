  <data key="d12">1772784708</data>
  <data key="d13"></data>
</edge>
<edge source="Player" target="GvG Instance">
  <data key="d7">1.0</data>
  <data key="d8">A Player must meet specific conditions (no troops, no wounded soldiers, main city not in combat) to enter the GvG Instance.</data>
  <data key="d9">entry condition,participation</data>
  <data key="d10">chunk-978055161286ec0d66cfcb71c8e04785</data>
