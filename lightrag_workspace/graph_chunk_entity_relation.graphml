  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Battle Session" target="UTC Time">
  <data key="d7">1.0</data>
  <data key="d8">Battle Sessions are scheduled based on UTC Time to allow players from different time zones to participate.</data>
