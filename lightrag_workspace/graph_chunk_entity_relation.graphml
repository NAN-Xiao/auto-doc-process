  <data key="d12">1772784708</data>
  <data key="d13"></data>
</edge>
<edge source="Player" target="Rallied Troops">
  <data key="d7">1.0</data>
  <data key="d8">Players can form Rallied Troops with alliance members to launch a stronger assault on a Neutral Building.</data>
  <data key="d9">coordinated attack,military cooperation</data>
  <data key="d10">chunk-a512646597d2b7b2699f5e2e5c8f4a4e</data>
