  <data key="d13"></data>
</edge>
<edge source="Player" target="Total Alliance Combat Power">
  <data key="d7">1.0</data>
  <data key="d8">The Total Alliance Combat Power is calculated by summing the personal combat power of each Player in the sign-up list.</data>
