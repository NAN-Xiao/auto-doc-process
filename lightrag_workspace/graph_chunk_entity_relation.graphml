  <data key="d12">1772784708</data>
  <data key="d13"></data>
</edge>
<edge source="Player" target="Garrison Troops">
  <data key="d7">1.0</data>
  <data key="d8">Players from the occupying alliance station Garrison Troops in a Neutral Building to defend it from attacks.</data>
  <data key="d9">defense,occupation maintenance</data>
  <data key="d10">chunk-a512646597d2b7b2699f5e2e5c8f4a4e</data>
