  <data key="d13"></data>
</edge>
<edge source="Player" target="Entry Conditions">
  <data key="d7">1.0</data>
  <data key="d8">Players must satisfy all Entry Conditions, such as having no troops created, to be allowed into the GVG Battle Instance.</data>
