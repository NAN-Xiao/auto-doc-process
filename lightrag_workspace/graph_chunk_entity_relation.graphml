  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Blackboard" target="External Configuration Table">
  <data key="d7">1.0</data>
  <data key="d8">The Blackboard loads data from External Configuration Tables, making the data selectable via dropdown lists in the editor tool interface.</data>
  <data key="d9">data integration,editor interface</data>
  <data key="d10">chunk-0a1bbafca3103b090e8933ba19fbacf9</data>
