  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Player" target="Neutral Buildings">
  <data key="d7">1.0</data>
  <data key="d8">Players can attack Neutral Buildings using personal or rallied troops to eliminate the garrison and change the building's ownership.</data>
  <data key="d9">military assault,occupation</data>
  <data key="d10">chunk-a512646597d2b7b2699f5e2e5c8f4a4e</data>
