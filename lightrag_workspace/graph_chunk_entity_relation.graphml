  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Blackboard" target="Custom Variable">
  <data key="d7">1.0</data>
  <data key="d8">The Blackboard manages Custom Variables, which can be used and modified by trigger logic and condition judgments.</data>
  <data key="d9">logic modification,variable management</data>
  <data key="d10">chunk-0a1bbafca3103b090e8933ba19fbacf9</data>
  <data key="d11">D:\work\A_elex\策划表\doctment\processed\20260306_150640\GVG功能制作文档</data>
  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Blackboard" target="Trigger">
  <data key="d7">1.0</data>
  <data key="d8">Triggers use data (from configuration tables or custom variables) loaded in the Blackboard as parameters to execute their logic.</data>
  <data key="d9">logic execution,parameter usage</data>
