  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Battle Instance" target="Exit Button">
  <data key="d7">1.0</data>
  <data key="d8">The Exit Button within the Battle Instance allows a player to leave and return to their Home Server.</data>
