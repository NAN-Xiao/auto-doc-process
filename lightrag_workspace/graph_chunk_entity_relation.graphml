  <data key="d12">1772784708</data>
  <data key="d13"></data>
</edge>
<edge source="Player" target="Spawn Point">
  <data key="d7">1.0</data>
  <data key="d8">A Player's Main City occupies a Spawn Point within their Alliance's Spawn Area upon entering the GvG Instance, assigned in order of entry.</data>
  <data key="d9">occupation,sequential assignment</data>
