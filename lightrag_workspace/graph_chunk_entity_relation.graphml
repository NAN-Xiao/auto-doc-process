  <data key="d12">1772784708</data>
  <data key="d13"></data>
</edge>
<edge source="Player" target="Player Personal Data Snapshot">
  <data key="d7">1.0</data>
  <data key="d8">A Player Personal Data Snapshot is taken when a player first enters the instance, isolating their in-instance state from changes on the home server.</data>
  <data key="d9">instance isolation,state preservation</data>
  <data key="d10">chunk-a512646597d2b7b2699f5e2e5c8f4a4e</data>
