  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Blackboard" target="InstanceGameConfig Table">
  <data key="d7">1.0</data>
  <data key="d8">Associated via InstanceGroup Id, the InstanceGameConfig Table provides constant values to the Blackboard for use as trigger parameters.</data>
  <data key="d9">constant provisioning,key-value association</data>
  <data key="d10">chunk-0a1bbafca3103b090e8933ba19fbacf9</data>
