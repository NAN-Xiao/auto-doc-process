  <data key="d13"></data>
</edge>
<edge source="Player" target="Shield Effect">
  <data key="d7">1.0</data>
  <data key="d8">Upon first entering the GVG Battle Instance, a Player's main city in their home server automatically receives a Shield Effect.</data>
  <data key="d9">protection,status effect</data>
  <data key="d10">chunk-9fb8c70f0427ab727390ab4ab71583f4</data>
