  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Alliance" target="GvG Instance">
  <data key="d7">1.0</data>
  <data key="d8">Two Alliances compete against each other within the GvG Instance, with members participating or spectating.</data>
  <data key="d9">competition,participation</data>
  <data key="d10">chunk-978055161286ec0d66cfcb71c8e04785</data>
  <data key="d11">D:\work\A_elex\策划表\doctment\processed\20260306_150640\GVG功能制作文档</data>
  <data key="d12">1772784708</data>
  <data key="d13"></data>
</edge>
<edge source="Alliance" target="Framework Demo Version">
  <data key="d7">1.0</data>
  <data key="d8">In the framework demo version, alliances must meet specific conditions (like ranking or member count) to be eligible to register for the GVG activity.</data>
  <data key="d9">demonstration,eligibility</data>
  <data key="d10">chunk-87d8ac677645393e5a5073d98d4850f1</data>
