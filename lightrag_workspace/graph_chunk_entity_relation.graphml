  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Player" target="City Teleport">
  <data key="d7">1.0</data>
  <data key="d8">Players can use the City Teleport function to move their city within the instance, facilitating strategic positioning.</data>
  <data key="d9">relocation,strategic mobility</data>
  <data key="d10">chunk-a512646597d2b7b2699f5e2e5c8f4a4e</data>
