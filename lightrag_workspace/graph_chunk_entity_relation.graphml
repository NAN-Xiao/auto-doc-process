  <data key="d12">1772784708</data>
  <data key="d13"></data>
</edge>
<edge source="Alliance" target="GVG Sign-up Activity">
  <data key="d7">1.0</data>
  <data key="d8">The GVG Sign-up Activity allows eligible Alliances to register their members for the competition.</data>
  <data key="d9">eligibility,participation</data>
  <data key="d10">chunk-fe1fd6e30ee3ce0c5ba91f5585fb3840</data>
