  <data key="d13"></data>
</edge>
<edge source="Player" target="GVG Interface">
  <data key="d7">1.0</data>
  <data key="d8">Players from alliances that did not sign up or are ineligible can only access a specific, limited GVG Interface after the registration phase.</data>
  <data key="d9">access,view</data>
  <data key="d10">chunk-29eecccea7490051a78857d0a2121a87</data>
