  <data key="d12">1772784707</data>
  <data key="d13"></data>
</edge>
<edge source="Player" target="Hospital Building">
  <data key="d7">1.0</data>
  <data key="d8">The Hospital Building allows players to heal wounded troops with reduced resource costs and no upper limit while inside the instance.</data>
  <data key="d9">healing enhancement,resource efficiency</data>
  <data key="d10">chunk-a512646597d2b7b2699f5e2e5c8f4a4e</data>
