  <data key="d12">1772784708</data>
  <data key="d13"></data>
</edge>
<edge source="Player" target="Original Server">
  <data key="d7">1.0</data>
  <data key="d8">When a Player enters a GvG Instance, their actions in the Original Server are restricted (cannot send troops), and their Main City gains a Protective Shield.</data>
  <data key="d9">protection,restriction</data>
  <data key="d10">chunk-978055161286ec0d66cfcb71c8e04785</data>
