  <data key="d12">1772784708</data>
  <data key="d13"></data>
</edge>
<edge source="Player" target="Personal Troops">
  <data key="d7">1.0</data>
  <data key="d8">Players can attack Neutral Buildings using their Personal Troops without assistance from other players.</data>
  <data key="d9">individual assault,military action</data>
  <data key="d10">chunk-a512646597d2b7b2699f5e2e5c8f4a4e</data>
