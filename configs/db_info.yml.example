# 数据库配置
# 复制本文件为 db_info.yml 并填入真实连接信息

database:
  enabled: true                    # 是否启用数据库
  host: localhost                  # 数据库主机
  port: 5432                       # 数据库端口
  database: slg_config             # 数据库名称
  user: postgres                   # 用户名
  password: ""                     # 密码（请修改为实际密码）
