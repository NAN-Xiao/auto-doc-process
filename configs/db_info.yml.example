# 数据库配置模板 - 复制为 db_info.yml 并填入实际值
#
# 要求: PostgreSQL 14+ with pgvector 扩展
# 安装 pgvector: CREATE EXTENSION IF NOT EXISTS vector;
#
# 首次部署步骤:
#   1. 创建数据库:  CREATE DATABASE "slg_config";
#   2. 启用扩展:    CREATE EXTENSION IF NOT EXISTS vector;
#   3. 程序首次运行会自动创建所需表
database:
  enabled: true
  host: localhost
  port: 5432
  database: slg_config
  user: postgres
  password: "<YOUR_PASSWORD>"




