# ===========================================
# 数据库配置 - db_info.yml
# ===========================================
# 复制本文件为 db_info.yml 并填写真实连接信息
#
# 要求：
#   - PostgreSQL 14+
#   - 已安装 pgvector 扩展（deploy.bat install 会自动尝试安装）
# ===========================================

database:
  enabled: true
  host: localhost
  port: 5432
  database: ""            # 数据库名（deploy.bat 会自动创建）
  user: postgres
  password: ""            # 数据库密码
