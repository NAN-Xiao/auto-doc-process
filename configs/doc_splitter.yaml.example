# ===========================================
# 文档拆分配置 - doc_splitter.yaml
# ===========================================
# 复制本文件为 doc_splitter.yaml 并按需修改
#
# 主要内容：
#   - 文本分割配置（chunk大小、重叠、分隔符）
#   - 图片命名配置（LLM智能命名 vs 简单模式）
#   - 上下文提取配置（图片命名时的上下文范围）
#   - 文本去重配置（删除重复内容）
#   - 输出配置（目录结构、时间戳）
#   - 支持的文档格式（PDF、DOCX）
#   - 处理选项（跳过已存在、错误处理）
# ===========================================

# ===========================================
# DeepSeek LLM 配置（图片智能命名等功能使用）
# ===========================================
deepseek:
  api_key: ""                                        # DeepSeek API Key（请替换为你的真实 Key）
  default_model: "deepseek-chat"                     # 默认模型

doc_splitter:
  # 文本分割配置
  text_splitter:
    chunk_size: 1000      # 每个文本块的最大字符数，影响RAG检索粒度
    chunk_overlap: 200    # 相邻块之间的重叠字符数，保证上下文连贯性
    separators:
      - "\n\n"
      - "\n"
      - "。"
      - "！"
      - "？"
      - "；"
      - "，"
      - " "
      - ""

  # 图片命名配置
  image_naming:
    use_llm: true         # 是否使用LLM智能命名（false=简单模式，true=AI模式）
    max_length: 18        # 图片名称最大长度

    llm:                  # LLM模式配置（仅use_llm=true时生效）
      api_base: "https://api.deepseek.com"
      temperature: 0.7
      max_tokens: 100
      frequency_penalty: 0.3
      presence_penalty: 0.2

    keywords:             # 简单模式关键词（从周围文本中提取）
      - "图"
      - "表"
      - "示意"
      - "流程"
      - "结构"
      - "架构"
      - "模型"
      - "界面"
      - "截图"

  # 上下文提取配置（图片命名时使用）
  context_extraction:
    max_length: 600
    word_lookback_paragraphs: 8
    word_lookahead_paragraphs: 5
    pdf_prev_page_length: 400
    pdf_next_page_length: 400

  # 文本去重配置
  text_deduplication:
    enabled: true
    min_text_length: 10
    min_pattern_length: 3
    repeat_ratio_threshold: 0.6

  # 输出配置
  output:
    root_dir: "processed"
    structure: "nested"
    add_timestamp: true
    verbose: true

  # 支持的文档格式
  supported_formats:
    - ".pdf"
    - ".docx"

  # 处理选项
  processing:
    skip_existing: false
    continue_on_error: true

# ===========================================
# 路径配置（相对路径基于 auto-doc/ 目录）
# ===========================================
paths:
  documents_dir: "../"
  processed_subdir: "processed"
  excel_dir: "../excel"

# ===========================================
# 向量模型配置
# ===========================================
embedding:
  model: "BAAI/bge-small-zh-v1.5"
  batch_size: 16
  huggingface:
    cache_folder: "./models"
    device: "cpu"
    normalize_embeddings: true
